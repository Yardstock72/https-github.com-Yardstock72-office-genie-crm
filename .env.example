# ================================================
# Office Genie CRM — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to GitHub
# ================================================

# CRM Supabase project (the central hub)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_CRM_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Used server-side only (API routes, server components)
SUPABASE_SERVICE_KEY=eyJ...

# App URL (for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
